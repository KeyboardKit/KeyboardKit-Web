<footer class="site-footer">
  <hr />
  <data class="u-url" href="{{ "/" | relative_url }}"></data>
  <div class="wrapper">
    <div class="row">
      {%- assign pages = site.pages -%}
      {%- assign paths_site = site.footer_pages_sitemap -%}
      {%- assign paths_app = site.footer_pages_app -%}
      
      <div class="column">
        <p class="footer-toggle">Site</p>
        <div class="footer-content">
          {% include kankoda/site/footer-links paths=site.footer.sitemap %}
        </div>
      </div>

      <div class="column">
        <p class="footer-toggle">Licensing</p>
        <div class="footer-content">
          <a href="/pro">KeyboardKit Pro</a>
          <a href="/pricing">Pricing</a>
          <a href="/business-licenses">Business Licenses</a>
        </div>
      </div>

      <div class="column">
        <p class="footer-toggle">News</p>
        <div class="footer-content">
          <a href="{{site.urls.blog}}">Blog</a>
          <a href="{{site.urls.rss}}">RSS</a>
          <a href="{{site.urls.newsletter}}">Newsletter</a>
        </div>
      </div>

      <div class="column">
        <p class="footer-toggle">Code</p>
        <div class="footer-content">
          <a href="{{site.urls.github}}">GitHub</a>
          <a href="{{site.urls.docs}}">Documentation</a>
          <a href="{{site.urls.issues}}">Issue Tracker</a>
        </div>
      </div>

      <div class="column">
        <p class="footer-toggle">Social</p>
        <div class="footer-content">
          <a href="{{site.urls.email}}">E-mail</a>
          <a href="{{site.urls.bluesky}}">Bluesky</a>
          <a href="{{site.urls.mastodon}}">Mastodon</a>
          <a href="{{site.urls.reddit}}">Reddit</a>
        </div>
      </div>
    </div>
    
    <div class="copyright">
      © {{site.copyright_year}} <a href="{{site.copyright_url}}">{{site.copyright_owner}}</a>. All rights reserved.
    </div>
  </div>
</footer>
