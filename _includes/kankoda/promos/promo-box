{% comment %}
Promo box for displaying features with title, image, description, and CTAs.
  Parameters:
  - title: A heading text for the feature box
  - title-class: A heading text CSS class
  - large-title: A large heading text for the feature box
  - image: (required) The image source path
  - image-class: The image CSS class
  - text: (required) The descriptive text/content
  - class: Optional css class (e.g., "slide-in delay-1")
  - hr: Show horizontal rule (1 or 0, defaults to 1)
  - hr-class: CSS class for the horizontal rule
  - cta: Custom text for a CTA button
  - cta-class: The CSS class for a CTA button
  - cta-link: The URL for a CTA button
  - cta2: Custom text for a second CTA button
  - cta-class: The CSS class for a second CTA button
  - cta2-link: The URL for a second CTA button
{% endcomment %}

<div class="promo-box{% if include.class %} {{include.class}}{% endif %}">
  {% if include.title %}
  <h3 class="{{include.title-class}}">{{ include.title }}</h3>
  {% endif %}
  {% if include.hr or include.class contains "with-separator" %}
  <hr class="{% if include.hr-class %}{{ include.hr-class }}{% endif %}" />
  {% endif %}
  <img src="{{ include.image }}" alt="{{ include.title }} feature" class="{{include.image-class}}" />
  <p>
    {{ include.text }}
  </p>
  {% if include.cta-link or include.cta2_link %}
  <div class="cta">
    {% if include.cta-link %}
    <a class="{{ include.cta-class | default: 'secondary' }}" href="{{ include.cta-link }}">
      {{ include.cta | default:"Learn more" }}
    </a>
    {% endif %}
    {% if include.cta2-link %}
    <a class="{{ include.cta2-class | default: 'primary' }}" href="{{ include.cta2-link }}">
      {{ include.cta2 }}
    </a>
    {% endif %}
  </div>
  {% endif %}
</div>