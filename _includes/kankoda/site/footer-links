{%- for path in include.paths -%}
  {%- assign current-page = site.pages | where: "path", path | first -%}
  {%- assign title = current-page.menu-title | default: current-page.title -%}
  {%- if title -%}
  <a href="{{ current-page.url | relative_url }}">{{ title | escape }}</a>
  {%- endif -%}
{%- endfor -%}