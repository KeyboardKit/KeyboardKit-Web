{% if page.eyebrow %}
  <p class="page-eyebrow">{{page.eyebrow}}</p>
  <h1 class="{{page.title-color | default: page.subtitle-color | default:purple}} glass">{{page.title}}</h1>
{% else %}
  <h1>{{page.title}}</h1>
  {% if page.subtitle %}
    <h2 class="{{page.subtitle-color | default:purple}} glass">{{page.subtitle}}</h2>
  {% endif %}
{% endif %}
{% if page.intro %}
  <h3>{{page.intro}}</h3>
{% endif %}
