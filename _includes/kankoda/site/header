<header role="banner">
  <div class="wrapper wide">
    {% if site.header.icon %}
      <a class="brand-icon" href="/"><img src="{{site.header.icon}}" width="25" /></a>
    {% endif %}
    
    <a href="/" class="brand">{{ site.header.title }}</a>

    <button class="menu-toggle" aria-label="Toggle menu">
      <div class="menu-icon">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </button>

    <nav>
      {% for page_path in site.header.pages %}
        {% assign page = site.pages | where: "path", page_path | first %}
        {% if page.title %}
          <a href="{{ page.url | relative_url }}" {% if page.url == page.url %}class="{% if page.url == page.url %}active{% endif %}"{% endif %}>{{ page.title }}</a>
        {% endif %}
      {% endfor %}
    </nav>
  </div>
</header>