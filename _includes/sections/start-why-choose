<article class="wrapper wide slide-in">
  <h2>Why Choose KeyboardKit?</h2>
  <p>KeyboardKit is the most trusted Swift and SwiftUI framework for developers who want to build, scale, and ship custom keyboards.</p>
  <div class="grid col4 carousel mobile">
    {% for usp in site.data.usps %}
    <div class="glass">
      {% include kankoda/components/icon-badge color=usp.color name=usp.icon %}
      <h4>{{ usp.title }}</h4>
      <p>{{ usp.text }}</p>
    </div>
    {% endfor %}
  </div>
</article>