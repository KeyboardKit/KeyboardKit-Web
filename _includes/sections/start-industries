<article class="wrapper wide slide-in">
  <h2>Industries</h2>
  <p>KeyboardKit powers innovation across a wide range of industries and use cases.</p>
  <div class="grid col4 carousel mobile">
    {% assign featured_industries = site.data.industries | where: "featured", true %}
    {% for industry in featured_industries %}
    <div class="glass compact">
      {% include kankoda/components/icon-badge color="blue" name=industry.icon %}
      <h4>{{ industry.title }}</h4>
      <p>{{ industry.text }}</p>
    </div>
    {% endfor %}
  </div>
</article>